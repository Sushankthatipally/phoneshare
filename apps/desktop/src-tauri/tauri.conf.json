{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DropBeam",
  "version": "0.1.0",
  "identifier": "com.dropbeam.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DropBeam",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["binaries/dropbeam-backend"],
    "resources": ["../scripts/diagnose-mac.sh", "../scripts/diagnose-windows.ps1"]
  }
}
