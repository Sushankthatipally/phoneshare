{
  "name": "@dropbeam/mobile",
  "private": true,
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --noEmit --watch --preserveWatchOutput",
    "build:android": "eas build --platform android --profile preview --local",
    "build:ios": "eas build --platform ios --profile preview --local",
    "prebuild": "expo prebuild"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@dropbeam/crypto-core": "workspace:*",
    "@dropbeam/protocol": "workspace:*",
    "@dropbeam/shared-ui-rn": "workspace:*",
    "@expo/metro-runtime": "~4.0.1",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-background-fetch": "~13.0.0",
    "expo-camera": "~16.0.0",
    "expo-clipboard": "~7.0.0",
    "expo-constants": "~17.0.0",
    "expo-device": "~7.0.0",
    "expo-document-picker": "~13.0.0",
    "expo-file-system": "~18.0.0",
    "expo-haptics": "~14.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-linking": "~7.0.0",
    "expo-network": "~7.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-sharing": "~13.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-task-manager": "~12.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.0",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-quick-base64": "2.1.2",
    "react-native-quick-crypto": "^0.7.6",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "react-native-zeroconf": "^0.13.8"
