{
  "name": "@dropbeam/local-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "scripts": {
    "dev": "node src/dev.js",
    "start": "node src/index.js",
    "typecheck": "node --check src/config.js && node --check src/dev.js && node --check src/index.js && node --check src/store.js && node --check src/crypto.js && node --check src/discovery.js",
    "test": "node --test 'src/__tests__/*.test.js'",
    "bundle:js": "esbuild src/index.js --bundle --platform=node --target=node20 --format=cjs --outfile=dist/dropbeam-backend.cjs",
    "bundle:exe": "node bundle-sidecar.mjs"
  },
  "dependencies": {
    "@dropbeam/crypto-core": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "@yao-pkg/pkg": "^6.0.0"
  }
}
